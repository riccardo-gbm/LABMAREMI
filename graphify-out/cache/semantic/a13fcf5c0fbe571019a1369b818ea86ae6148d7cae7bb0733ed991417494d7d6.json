n", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_mock_data", "label": "Mock Data (static TypeScript files in src/data: products, categories, businessTypes, leads)", "file_type": "concept", "source_file": "README.md", "source_location": "README.md 'What's mocked vs. real' section", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "All lead company names, contacts, phones, and emails are fictional to avoid real customer data; the mock data files were deliberately shaped to match the future Supabase database schema so the Phase 2 migration is straightforward."}, {"id": "readme_quote_flow", "label": "Quote Request Flow (non-persistent, cosmetic reference number)", "file_type": "rationale", "source_file": "README.md", "source_location": "README.md 'What's mocked vs. real' section", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The quote form validates and shows a polished success state without persisting anything because Phase 1 has no backend; the reference number is intentionally cosmetic. Supports ?productos=<ids> pre-selection from the catalog."}, {"id": "readme_admin_dashboard_preview", "label": "Admin Dashboard Preview (/admin, footer link)", "file_type": "rationale", "source_file": "README.md", "source_location": "README.md 'Pages' and 'What's mocked vs. real' sections", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A visual preview only: every metric is derived at render time from the mock leads, so no persistence layer is needed in Phase 1; in Phase 2 it becomes a live internal tool for the sales team."}, {"id": "readme_phase2_supabase", "label": "Phase 2 Plan (Supabase backend, auth, quote persistence, real photos)", "file_type": "concept", "source_file": "README.md", "source_location": "README.md 'Phase 2 (planned)' section", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Supabase brings real product management, quote persistence, and authentication; hero Unsplash stock imagery gets swapped for real product photography, optionally with a Spline 3D hero scene, plus deployment hardening."}, {"id": "readme_no_backend_phase1", "label": "No-Backend Constraint (everything runs in the browser)", "file_type": "rationale", "source_file": "README.md", "source_location": "README.md 'What's mocked vs. real' section", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Phase 1 is a clickable demo: products/categories/leads are static TS files, contact details and the map location are placeholders, and nothing is persisted \u2014 the backend arrives only in Phase 2."}], "edges": [{"source": "readme_readme", "target": "readme_labmaremi_company", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": "intro paragraph", "weight": 1.0}, {"source": "readme_readme", "target": "docs_00_phase_1_scope_document", "relation": "cites", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": "link: docs/00-phase-1-scope.md", "weight": 1.0}, {"source": "readme_readme", "target": "readme_tech_stack", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": "'Tech stack' section", "weight": 1.0}, {"source": "readme_readme", "target": "readme_pages_routes", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": "'Pages' table", "weight": 1.0}, {"source": "readme_readme", "target": "readme_project_structure", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": "'Project structure' section", "weight": 1.0}, {"source": "readme_readme", "target": "readme_no_backend_phase1", 